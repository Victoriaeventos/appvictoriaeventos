# ============================================
# Variables de entorno para el frontend
# ============================================
# Copia este archivo a .env y rellena tus valores.
# En Vercel, configura estas variables en Project Settings > Environment Variables.
#
# IMPORTANTE: en Create React App, todas las variables expuestas al navegador
# deben empezar por REACT_APP_ (todas las que aparecen aquí ya lo cumplen).

# --- URL del backend ---
# En desarrollo (local): http://localhost:8000
# En producción: la URL pública de Render, ej. https://victoriaeventos-api.onrender.com
# Cuando configures dominio propio: https://api.victoriaeventos.com
REACT_APP_BACKEND_URL=http://localhost:8000
