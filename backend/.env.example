# ============================================
# Variables de entorno para el backend
# ============================================
# Copia este archivo a .env y rellena tus valores.
# En Render, configura estas variables en el dashboard del servicio.

# --- Base de datos MongoDB ---
# Cadena de conexión completa de MongoDB Atlas
# Ejemplo: mongodb+srv://usuario:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb://localhost:27017

# Nombre de la base de datos
DB_NAME=victoria_eventos_db

# --- Autenticación JWT ---
# Cadena larga y aleatoria (mínimo 32 caracteres) para firmar tokens.
# Genera una segura con: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=cambiame-por-una-clave-larga-y-aleatoria-en-produccion

# --- CORS ---
# Dominios autorizados a hacer peticiones al API, separados por coma.
# En desarrollo: http://localhost:3000
# En producción: https://victoriaeventos.com,https://www.victoriaeventos.com
CORS_ORIGINS=http://localhost:3000

# --- OpenAI ---
# Clave para la generación de imágenes con gpt-image-1
# Obtén la tuya en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Puerto (lo gestiona Render automáticamente, no es necesario tocarlo) ---
# PORT=8000
